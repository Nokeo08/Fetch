# Fetch Environment Variables
# Copy this file to .env and fill in the values
# Used by both local development and Docker Compose

# Authentication
# Required unless DISABLE_AUTH=true
APP_PASSWORD=your-secure-password-here

# Disable authentication (for reverse proxy setups)
# Set to "true" to disable auth completely
DISABLE_AUTH=false

# API token for REST API access
# Optional - if not set, API endpoints require session auth
API_TOKEN=

# Server Configuration
# HTTP server port
PORT=3000

# Database
# Path to SQLite database file
# Local development: ./data/fetch.db
# Docker: /data/fetch.db (mapped to volume automatically)
DATABASE_PATH=./data/fetch.db

# Session
# Secret for session cookie encryption
# If not set, a random secret will be generated on startup
# Recommended: set a stable value for production so sessions survive restarts
SESSION_SECRET=

# WebSocket URL (for development with separate frontend/backend)
# Leave empty in production / Docker (auto-detects from window.location)
VITE_WS_URL=ws://localhost:3000/ws
